{
  "name": "code-counter",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "package": "tauri build",
    "package:mac:universal": "tauri build --target universal-apple-darwin",
    "package:mac:aarch64": "tauri build --target aarch64-apple-darwin",
    "package:mac:x86_64": "tauri build --target x86_64-apple-darwin",
    "package:win:x86_64": "tauri build --target x86_64-pc-windows-msvc",
    "package:win:aarch64": "tauri build --target aarch64-pc-windows-msvc",
    "package:linux:x86_64": "tauri build --target x86_64-unknown-linux-gnu",
    "package:linux:aarch64": "tauri build --target aarch64-unknown-linux-gnu"
  },
  "dependencies": {
    "@tauri-apps/api": "2.0.1",
    "@tauri-apps/plugin-dialog": "2.0.1",
    "@tauri-apps/plugin-window": "^2.0.0-alpha.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.0.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
